# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Slack Signing Secret
SLACK_SIGNING_SECRET=

# Default working directory for Claude Code sessions
DEFAULT_CWD=/home/user/projects

# Anthropic API Key (used by Claude Code SDK)
ANTHROPIC_API_KEY=

# Optional: allowed Slack user IDs (comma-separated). Empty = allow all.
ALLOWED_USER_IDS=

# Optional: allowed channel IDs (comma-separated). Empty = allow all.
ALLOWED_CHANNEL_IDS=

# Session idle timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# Test server port for dashboard [t] Test (default: 4041)
# TEST_PORT=4041

# Slack message update interval in ms (default: 1500)
MESSAGE_UPDATE_INTERVAL_MS=1500

# Display flags — control what appears in Slack threads
# SHOW_TOOL_CALLS=1        # Show each tool call as a separate message (default: off)
# SHOW_TOOL_RESULTS=1      # Show tool output in thread (default: off)
# SHOW_STREAMING=1         # Stream text as Claude types (default: on)
# SHOW_TOOL_SUMMARY=1      # Show compact tool summary after completion (default: on)
